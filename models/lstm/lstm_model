import torch
import torch.nn as nn

# Bidirectional LSTM Classifier
class LSTMModel(nn.Module):

    def __init__(self, config):

        #initialize the LSTM model
        super(LSTMModel, self).__init__()

        # Read model parameters from config file
        self.input_size = config['model']['input_size']
        self.hidden_size = config['model']['hidden_size']
        self.num_layers = config['model']['num_layers']
        self.num_classes = config['model']['num_classes']
        self.dropout = config['model']['dropout']
        self.bidirectional = config['model'].get('bidirectional', True)

        if self.bidirectional:
            self.num_direcions = 2
        else:
            self.num_directions = 1

        # Define LSTM Layer
        self.lstm = nn.LSTM(
            input_size = self.input_size,
            hidden_size = self.hidden_size,
            num_layers = self.num_layers,
            batch_first = True,  # Batch size is the first dimension for input and output tensors
            dropout = self.dropout if self.num_layers > 1 else 0,
            bidirectional = self.bidirectional
        )

        # Define Dropout Layer
        self.dropout_layer = nn.Dropout(self.dropout)

        # Define Fully Connected Layer
        self.fc = nn.Linear(
            # of input features is the output of the LSTM layer, which is hidden_size * num_directions
            self.hidden_size * self.num_directions,
            # Output size is the number of classes for classification
            self.num_classes
        )

    # Define the forward pass with input tensor x of shape (batch_size, seq_length, input_size)
    def forward(self, x):

        # Pass the input through the LSTM layer
        # output shape is (batch_size, seq_length, hidden_size * num_directions)
        # hidden: final hidden state produced at the very last time step of the sequence, for every layer and every direction
        out, (hidden, cell) = self.lstm(x)

        # Use the last hidden state for classification and Concatenate the last hidden states from both directions if bidirectional
        if self.bidirectional:
            hidden = torch.cat((hidden[-2], hidden[-1]), dim = 1)
        else:
            hidden = hidden[-1]

        # Pass the hidden state through the dropout layer
        hidden = self.dropout_layer(hidden)

        # Pass the hidden state through the fully connected layer to get the output logits
        out = self.fc(hidden)

        return out